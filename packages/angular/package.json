{
  "name": "@ultratyped/angular",
  "version": "1.0.0",
  "description": "Angular adapter for UltraTyped",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "rollup -c"
  },
  "peerDependencies": {
    "@angular/core": "^14.0.0 || ^15.0.0 || ^16.0.0 || ^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "ultratyped": "^1.0.0"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "typing",
    "animation",
    "angular",
    "directive"
  ],
  "license": "MIT"
}
