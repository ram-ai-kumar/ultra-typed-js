{
  "name": "@ultratyped/typescript",
  "version": "1.0.0",
  "description": "TypeScript adapter for UltraTyped with enhanced type safety",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "rollup -c"
  },
  "dependencies": {
    "ultratyped": "^1.0.0"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "typing",
    "animation",
    "typescript",
    "adapter"
  ],
  "license": "MIT"
}
