{
  "name": "ultratyped-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Ultra-fast <2KB typing animation library",
  "workspaces": [
    "packages/*",
    "playground"
  ],
  "scripts": {
    "build": "npm run build -w packages/core && npm run build -w packages/alpine -w packages/angular -w packages/astro -w packages/lit -w packages/preact -w packages/react -w packages/solid -w packages/svelte -w packages/typescript -w packages/vue && npm run build -w playground",
    "dev": "npm run dev --workspace=playground",
    "bench": "node benchmarks/compare.js",
    "clean": "rm -rf packages/*/dist playground/dist",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "size:check": "size-limit",
    "size:report": "node scripts/size-report.js"
  },
  "devDependencies": {
    "@angular/core": "^18.0.0",
    "@angular/common": "^18.0.0",
    "@playwright/test": "^1.59.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@size-limit/file": "^11.0.0",
    "@size-limit/preset-small-lib": "^11.0.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "@vue/test-utils": "^2.4.6",
    "gzip-size": "^7.0.0",
    "happy-dom": "^15.11.6",
    "jsdom": "^25.0.1",
    "preact": "^10.25.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rollup": "^4.28.1",
    "rxjs": "^7.8.1",
    "size-limit": "^11.0.0",
    "solid-js": "^1.9.4",
    "tslib": "^2.8.1",
    "typescript": "^5.7.2",
    "vite": "^5.2.11",
    "vitest": "^2.1.8",
    "vue": "^3.5.13"
  },
  "license": "MIT"
}
