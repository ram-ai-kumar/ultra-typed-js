{
  "name": "ultratyped-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Ultra-fast <2KB typing animation library",
  "workspaces": [
    "packages/*",
    "playground"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspace=playground",
    "bench": "node benchmarks/compare.js",
    "clean": "rm -rf packages/*/dist playground/dist",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/react-hooks": "^8.0.1",
    "@vitest/ui": "^2.1.8",
    "@vue/test-utils": "^2.4.6",
    "gzip-size": "^7.0.0",
    "happy-dom": "^15.11.6",
    "jsdom": "^25.0.1",
    "preact": "^10.25.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rollup": "^4.28.1",
    "solid-js": "^1.9.4",
    "tslib": "^2.8.1",
    "typescript": "^5.7.2",
    "vite": "^5.2.11",
    "vitest": "^2.1.8",
    "vue": "^3.5.13"
  },
  "license": "MIT"
}
