{
  "name": "ultratyped-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Ultra-fast <2KB typing animation library",
  "workspaces": [
    "packages/*",
    "playground"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspace=playground",
    "bench": "node benchmarks/compare.js",
    "clean": "rm -rf packages/*/dist playground/dist"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "rollup": "^4.18.0",
    "tslib": "^2.6.2",
    "typescript": "^5.4.5",
    "gzip-size": "^7.0.0",
    "vite": "^5.2.11"
  },
  "license": "MIT"
}
